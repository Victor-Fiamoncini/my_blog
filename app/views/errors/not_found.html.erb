<% content_for :title, "Page Not Found" %>

<div class="flex flex-col items-center justify-center py-16 md:py-24">
  <div class="border-4 border-black bg-white shadow-[8px_8px_0px_#000] p-10 md:p-16 w-full max-w-2xl text-center">
    <p class="text-xs font-black uppercase tracking-[0.3em] mb-4 opacity-70">Error 404</p>

    <h1 class="text-6xl sm:text-8xl font-black uppercase leading-none tracking-tight mb-6 bg-blue-400 inline-block px-4 py-2">
      404
    </h1>

    <p class="text-2xl font-black uppercase tracking-tight mb-4">Page Not Found</p>

    <p class="text-gray-600 font-bold mb-10">
      The post you're looking for doesn't exist or may have been removed.
    </p>

    <%= link_to "← Back to Posts", root_path, class: "inline-block border-4 border-black bg-blue-400 px-6 py-3 font-black uppercase tracking-widest shadow-[6px_6px_0px_#000] hover:translate-x-[6px] hover:translate-y-[6px] hover:shadow-none transition-all" %>
  </div>
</div>
