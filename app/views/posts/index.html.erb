<% content_for :title, "Home" %>

<%# Hero %>
<section class="mb-16">
  <div class="border-4 border-black bg-blue-400 shadow-[8px_8px_0px_#000] p-6 sm:p-10 md:p-16">
    <p class="text-xs font-black uppercase tracking-[0.3em] mb-4 opacity-70">Welcome to</p>

    <div class="flex items-center justify-start gap-2 mb-3 flex-wrap">
      <h1 class="text-4xl sm:text-5xl md:text-7xl font-black uppercase leading-none tracking-tight flex items-center gap-4">
        Victor's Blog <span class="text-4xl sm:text-5xl">👨‍💻</span>
      </h1>
    </div>

    <p class="text-sm font-black uppercase tracking-[0.25em] mb-6 opacity-70">Technical Blog</p>

    <p class="text-base md:text-xl font-bold">
      A technical blog about software engineering, web development and Ruby 💎 by Victor Fiamon.
    </p>
  </div>
</section>

<%# Posts Grid %>
<section>
  <div class="flex items-center justify-between mb-8">
    <h2 class="text-2xl md:text-3xl font-black uppercase tracking-tight">Latest Posts</h2>

    <span class="text-xs md:text-sm font-bold uppercase tracking-widest bg-black text-white px-3 py-1"><%= @posts.total_count %> posts</span>
  </div>

  <% if @posts.empty? %>
    <div class="border-4 border-black bg-white shadow-[6px_6px_0px_#60a5fa] p-12 text-center">
      <p class="text-xl font-black uppercase">No posts yet.</p>

      <p class="text-gray-500 font-bold mt-2">Check back soon!</p>
    </div>
  <% else %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @posts.each do |post| %>
        <article class="border-4 border-black bg-white shadow-[6px_6px_0px_#60a5fa] flex flex-col hover:translate-x-[6px] hover:translate-y-[6px] hover:shadow-none transition-all duration-150">
          <div class="p-6 flex-1 flex flex-col">
            <div class="flex items-center gap-3 mb-4">
              <time datetime="<%= post.published_at.to_date %>" class="text-xs font-black uppercase tracking-widest bg-black text-white px-2 py-1">
                <%= post.published_at.strftime("%b %d, %Y") %>
              </time>
            </div>

            <h3 class="text-xl font-black uppercase leading-tight mb-3 flex-1">
              <%= link_to post.title, post_path(post.slug), class: "hover:text-blue-400 transition-colors" %>
            </h3>

            <% if post.excerpt.present? %>
              <p class="text-gray-600 font-medium text-sm leading-relaxed mb-4">
                <%= truncate(post.excerpt, length: 120) %>
              </p>
            <% end %>

            <%= link_to "Read more →", post_path(post.slug), class: "mt-auto inline-block border-4 border-black bg-white px-4 py-2 text-sm font-black uppercase tracking-widest hover:bg-blue-400 shadow-[4px_4px_0px_#60a5fa] hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none transition-all" %>
          </div>
        </article>
      <% end %>
    </div>

    <div class="mt-10">
      <%= paginate @posts %>
    </div>
  <% end %>
</section>
