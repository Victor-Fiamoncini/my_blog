<% content_for :title, "Posts" %>

<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-4xl font-black uppercase tracking-tight">Posts</h1>
    <p class="text-sm font-bold text-gray-500 uppercase tracking-widest mt-1">Manage all your blog posts</p>
  </div>
  <%= link_to "+ New Post", new_dashboard_post_path, class: "inline-flex items-center gap-2 border-4 border-black bg-blue-400 px-6 py-3 font-black uppercase tracking-widest text-sm hover:bg-blue-300 shadow-[4px_4px_0px_#60a5fa] hover:translate-x-[4px] hover:translate-y-[4px] hover:shadow-none transition-all" %>
</div>

<% if flash[:success] %>
  <div class="mb-6 border-4 border-black bg-green-400 shadow-[4px_4px_0px_#60a5fa] px-5 py-3 font-bold uppercase text-sm">
    <%= flash[:success] %>
  </div>
<% end %>

<div class="border-4 border-black bg-white shadow-[6px_6px_0px_#60a5fa] overflow-hidden">
  <% if @posts.empty? %>
    <div class="p-12 text-center">
      <p class="text-xl font-black uppercase">No posts yet.</p>
      <%= link_to "Create your first post →", new_dashboard_post_path, class: "mt-4 inline-block underline font-bold" %>
    </div>
  <% else %>
    <table class="w-full">
      <thead class="border-b-4 border-black bg-black text-white">
        <tr>
          <th class="text-left px-6 py-4 text-xs font-black uppercase tracking-widest">Title</th>
          <th class="text-left px-6 py-4 text-xs font-black uppercase tracking-widest hidden md:table-cell">Status</th>
          <th class="text-left px-6 py-4 text-xs font-black uppercase tracking-widest hidden lg:table-cell">Date</th>
          <th class="text-right px-6 py-4 text-xs font-black uppercase tracking-widest">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y-4 divide-black">
        <% @posts.each do |post| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-6 py-4">
              <p class="font-black text-sm uppercase leading-tight"><%= post.title %></p>
              <p class="text-xs text-gray-400 font-mono mt-1"><%= post.slug %></p>
            </td>
            <td class="px-6 py-4 hidden md:table-cell">
              <%= button_to post.is_published? ? "Published" : "Draft",
                    toggle_published_dashboard_post_path(post),
                    method: :patch,
                    class: "cursor-pointer text-xs font-black uppercase tracking-widest px-3 py-1 border-2 border-black shadow-[2px_2px_0px_#60a5fa] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all #{post.is_published? ? "bg-green-400 hover:bg-green-300" : "bg-gray-200 hover:bg-blue-100"}" %>
            </td>
            <td class="px-6 py-4 hidden lg:table-cell">
              <span class="text-xs font-bold text-gray-500"><%= post.created_at.strftime("%b %d, %Y") %></span>
            </td>
            <td class="px-6 py-4">
              <div class="flex items-center justify-end gap-2">
                <% if post.is_published? %>
                  <%= link_to "View", post_path(post.slug), target: "_blank", class: "text-xs font-black uppercase tracking-widest border-2 border-black px-3 py-1.5 hover:bg-blue-100 shadow-[2px_2px_0px_#60a5fa] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all" %>
                <% end %>
                <%= link_to "Edit", edit_dashboard_post_path(post), class: "text-xs font-black uppercase tracking-widest border-2 border-black px-3 py-1.5 hover:bg-blue-100 shadow-[2px_2px_0px_#60a5fa] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all" %>
                <%= button_to "Delete", dashboard_post_path(post), method: :delete,
                      data: { turbo_confirm: "Are you sure you want to delete '#{post.title}'?" },
                      class: "cursor-pointer text-xs font-black uppercase tracking-widest border-2 border-red-600 text-red-600 px-3 py-1.5 hover:bg-red-50 shadow-[2px_2px_0px_#991b1b] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <div class="px-6 py-4 border-t-4 border-black bg-gray-50">
      <%= paginate @posts %>
    </div>
  <% end %>
</div>
