<!DOCTYPE html>
<html lang="en">
  <%= render "layouts/head", title_suffix: "Victor's Blog" %>

  <body class="bg-stone-400 font-sans antialiased">
    <header class="border-b-4 border-black bg-white sticky top-0 z-50 shadow-[0px_4px_0px_0px_#60a5fa]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between py-3">
        <%= link_to "Victor's Blog", root_path, class: "text-2xl font-black uppercase tracking-tight hover:text-blue-400 transition-colors" %>

        <nav class="flex items-center gap-4">
          <%= link_to "Posts", root_path, class: "text-sm font-black uppercase tracking-widest border-b-4 border-black hover:border-blue-400 transition-all pb-1" %>
        </nav>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
      <%= yield %>
    </main>

    <footer class="border-t-4 border-black bg-white mt-16 md:mt-24">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col items-center gap-4 min-[425px]:flex-row min-[425px]:justify-between">
        <div class="flex items-center gap-5">
          <%= link_to "https://www.linkedin.com/in/victor-fiamoncini-b74b72159/", target: "_blank", rel: "noopener noreferrer", title: "LinkedIn", class: "inline-flex items-center justify-center bg-black text-white border-2 border-black p-1.5 shadow-[3px_3px_0px_#60a5fa] hover:bg-gray-800 hover:translate-x-[3px] hover:translate-y-[3px] hover:shadow-none transition-all" do %>
            <%= render "icons/linkedin" %>
          <% end %>

          <%= link_to "https://github.com/Victor-Fiamoncini", target: "_blank", rel: "noopener noreferrer", title: "GitHub", class: "inline-flex items-center justify-center bg-black text-white border-2 border-black p-1.5 shadow-[3px_3px_0px_#60a5fa] hover:bg-gray-800 hover:translate-x-[3px] hover:translate-y-[3px] hover:shadow-none transition-all" do %>
            <%= render "icons/github" %>
          <% end %>

          <%= link_to "https://www.instagram.com/victorfiamon", target: "_blank", rel: "noopener noreferrer", title: "Instagram", class: "inline-flex items-center justify-center bg-black text-white border-2 border-black p-1.5 shadow-[3px_3px_0px_#60a5fa] hover:bg-gray-800 hover:translate-x-[3px] hover:translate-y-[3px] hover:shadow-none transition-all" do %>
            <%= render "icons/instagram" %>
          <% end %>
        </div>

        <%= link_to "© #{Time.current.year} Victor Fiamoncini", "https://www.victorfiamon.com.br/", target: "_blank", rel: "noopener noreferrer", class: "text-sm font-bold text-black hover:underline transition-all" %>
      </div>
    </footer>
  </body>
</html>
