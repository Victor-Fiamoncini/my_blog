<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for?(:title) ? "#{yield(:title)} — Dashboard" : "Dashboard" %></title>
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" href="/icon.png" type="image/png">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link rel="stylesheet" href="https://unpkg.com/easymde/dist/easymde.min.css">
    <script src="https://unpkg.com/easymde/dist/easymde.min.js"></script>
  </head>

  <body class="bg-stone-400 font-sans antialiased">
    <header class="border-b-4 border-black bg-white sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
        <%= link_to raw("Victor's Blog <span class=\"text-base font-bold text-gray-500\">/ Dashboard</span>"), dashboard_root_path, class: "text-2xl font-black uppercase tracking-tight hover:text-blue-400 transition-colors" %>
        <div class="flex items-center gap-6">
          <%= link_to "View Blog", root_path, class: "text-sm font-black uppercase tracking-widest hover:underline" %>
          <%= button_to "Logout", logout_path, method: :delete, class: "cursor-pointer text-sm font-black uppercase tracking-widest bg-black text-white px-4 py-2 hover:bg-gray-800 border-2 border-black shadow-[3px_3px_0px_#60a5fa] hover:translate-x-[3px] hover:translate-y-[3px] hover:shadow-none transition-all" %>
        </div>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <%= yield %>
    </main>
  </body>
</html>
